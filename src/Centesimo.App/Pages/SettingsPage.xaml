<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" x:Class="Centesimo.App.Pages.SettingsPage" Title="Impostazioni" SafeAreaEdges="All"><ScrollView><VerticalStackLayout Padding="20,16" Spacing="20"><VerticalStackLayout Spacing="2"><Label Text="Impostazioni" Style="{StaticResource HeadlineLarge}"/><Label Text="Gestisci automazioni e dati locali dell'app." Style="{StaticResource BodyMedium}"/></VerticalStackLayout><Label Text="AUTOMAZIONI" Style="{StaticResource LabelLarge}"/><Border Style="{StaticResource SurfaceCard}"><Grid ColumnDefinitions="Auto,*,Auto"><Label Text="↻" FontSize="26" VerticalOptions="Center"/><VerticalStackLayout Grid.Column="1" Spacing="2" Margin="14,0"><Label Text="Pagamenti regolari" Style="{StaticResource TitleLarge}"/><Label Text="Gestisci scadenze e spese automatiche" Style="{StaticResource BodyMedium}"/></VerticalStackLayout><Button Grid.Column="2" Text="›" Style="{StaticResource IconButton}" Clicked="OnRecurringPaymentsClicked"/></Grid></Border><Label Text="DATI" Style="{StaticResource LabelLarge}"/><Border Style="{StaticResource SurfaceCard}"><VerticalStackLayout Spacing="12"><Label Text="Importa da Money Manager" Style="{StaticResource TitleLarge}"/><Label Text="Il backup resta sul dispositivo: viene letta soltanto una copia temporanea locale, poi eliminata." Style="{StaticResource BodyMedium}"/><Button Text="Scegli backup" Style="{StaticResource TextActionButton}" Clicked="OnImportClicked" IsEnabled="{Binding CanImport}"/></VerticalStackLayout></Border><Border Style="{StaticResource TonalCard}" IsVisible="{Binding HasPreview}"><VerticalStackLayout Spacing="12"><Label Text="Backup analizzato" Style="{StaticResource TitleLarge}"/><Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"><VerticalStackLayout><Label Text="{Binding PreviewResult.CategoriesCount}" Style="{StaticResource TitleLarge}"/><Label Text="Nuove categorie" Style="{StaticResource BodyMedium}"/></Vertica