<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Centesimo.App.Pages.RecurringPaymentsPage"
             Title="Regolari"
             SafeAreaEdges="All">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="24">
            <VerticalStackLayout Spacing="4">
                <Label Text="Pagamenti regolari"
                       Style="{StaticResource HeadlineLarge}"
                       SemanticProperties.HeadingLevel="Level1" />
                <Label Text="Gestisci le spese che si ripetono nel tempo."
                       Style="{StaticResource BodyMedium}" />
            </VerticalStackLayout>

            <Border Style="{StaticResource SurfaceCard}">
                <VerticalStackLayout Style="{StaticResource EmptyStateLayout}">
                    <Label Text="Nessun pagamento regolare"
                           Style="{StaticResource TitleLarge}"
                           HorizontalTextAlignment="Center"
                           SemanticProperties.HeadingLevel="Level2" />
                    <Label Text="Le prossime spese automatiche appariranno qui."
                           Style="{StaticResource BodyMedium}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
