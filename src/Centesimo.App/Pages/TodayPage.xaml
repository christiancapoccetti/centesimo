<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" x:Class="Centesimo.App.Pages.TodayPage" Title="Oggi" SafeAreaEdges="All">
 <Grid Padding="22,14,22,16" RowDefinitions="*,56" RowSpacing="12">
  <CollectionView ItemsSource="{Binding Expenses}" SelectionMode="None" ItemSizingStrategy="MeasureFirstItem">
   <CollectionView.Header><VerticalStackLayout Spacing="24" Padding="0,8,0,14">
    <Grid ColumnDefinitions="*,Auto"><VerticalStackLayout Spacing="2"><Label Text="Ciao!" Style="{StaticResource HeadlineLarge}" /><Label Text="Ecco come sta andando il tuo mese." Style="{StaticResource BodyMedium}" /></VerticalStackLayout><Border Grid.Column="1" Style="{StaticResource CategoryIconContainer}" BackgroundColor="{StaticResource PrimaryContainerLight}" VerticalOptions="Center"><Label Text="€" Style="{StaticResource TitleLarge}" TextColor="{StaticResource PrimaryLight}" HorizontalOptions="Center" VerticalOptions="Center" /></Border></Grid>
    <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" />
    <Border Style="{StaticResource SurfaceCard}" IsVisible="{Binding HasError}"><Label Text="{Binding ErrorMessage}" TextColor="{StaticResource ErrorLight}" /></Border>
    <VerticalStackLayout Spacing="12"><Grid ColumnDefinitions="40,*,40"><Button Text="‹" Style="{StaticResource IconButton}" IsEnabled="{Binding CanGoPrevious}" Clicked="OnPreviousMonthClicked" /><Label Grid.Column="1" Text="{Binding MonthTitle}" Style="{StaticResource TitleMedium}" HorizontalTextAlignment="Center" VerticalOptions="Center" /><Button Grid.Column="2" Text="›" Style="{StaticResource IconButton}" IsEnabled="{Binding CanGoNext}" Clicked="OnNextMonthClicked" /></Grid><Border Style="{StaticResource TonalCard}" Padding="22"><VerticalStackLayout Spacing="8"><Label Text="QUESTO MESE" Style="{StaticResource LabelLarge}" TextColor="{StaticResource OnPrimaryContainerLight}" /><Label Text="{Binding MonthlyTotal}" Style="{StaticResource DisplaySmall}" TextColor="{StaticResource OnPrimaryContainerLight}" /><Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0"><Label Text="{Binding BudgetSummary}" Style="{StaticResource BodyMedium}" /><Label Grid.Column="1" Text="Budget" Style="{StaticResource LabelLarge}" /></Grid><ProgressBar Progress="{Binding BudgetProgress}" HeightRequest="6" ProgressColor="{StaticResource PrimaryLight}" /></VerticalStackLayout></Border></VerticalStackLayout>
    <VerticalStackLayout Spacing="12" IsVisible="{Binding HasCategories}"><Grid ColumnDefinitions="*,Auto"><Label Text="Panoramica" Style="{StaticResource TitleLarge}" /><Label Grid.Column="1" Text="Per categoria" Style="{StaticResource BodyMedium}" /></Grid><ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never"><HorizontalStackLayout BindableLayout.ItemsSource="{Binding Categories}" Spacing="10"><BindableLayout.ItemTemplate><DataTemplate><Border Style="{StaticResource SurfaceCard}" BackgroundColor="{Binding CardColor}" Padding="12" WidthRequest="168" HeightRequest="92"><Grid ColumnDefinitions="44,*" ColumnSpacing="10"><Border Style="{StaticResource CategoryIconContainer}" BackgroundColor="{Binding Color}"><Image Source="{Binding Icon, Converter={StaticResource CategoryIconSourceConverter}}" Style="{StaticResource CategoryIconImage}" /></Border><VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center"><Label Text="{Binding Name}" Style="{StaticResource TitleMedium}" MaxLines="1" LineBreakMode="TailTruncation" /><Label Text="{Binding AmountSummary}" Style="{StaticResource BodyMedium}" MaxLines="1" LineBreakMode="TailTruncation" /><Label Text="{Binding StatusLabel}" IsVisible="{Binding IsOverBudget}" TextColor="{StaticResource ErrorLight}" Style="{StaticResource LabelLarge}" /></VerticalStackLayout><Button Grid.ColumnSpan="2" BackgroundColor="Transparent" Text="" Clicked="OnCategoryClicked" CommandParameter="{Binding .}" /></Grid></Border></DataTemplate></BindableLayout.ItemTemplate></HorizontalStackLayout></ScrollView></VerticalStackLayout>
    <VerticalStackLayout Spacing="10"><Label Text="{Binding ExpenseSectionTitle}" Style="{StaticResource TitleLarge}" /><Label Text="{Binding EmptyMessage}" IsVisible="{Binding IsExpenseEmpty}" Style="{StaticResource BodyMedium}" /></VerticalStackLayout>
   </VerticalStackLayout></CollectionView.Header>
   <CollectionView.ItemTemplate><DataTemplate><Grid ColumnDefinitions="48,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" Padding="0,10"><Border Grid.RowSpan="2" Style="{StaticResource CategoryIconContainer}" BackgroundColor="{Binding Color}"><Image Source="{Binding Icon, Converter={StaticResource CategoryIconSourceConverter}}" Style="{StaticResource CategoryIconImage}" /></Border><Label Grid.Column="1" Text="{Binding CategoryName}" Style="{StaticResource TitleMedium}" /><Label Grid.Column="2" Text="{Binding Amount}" Style="{StaticResource TitleMedium}" /><HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="6"><Label Text="{Binding Date}" Style="{StaticResource BodyMedium}" /><Label Text="{Binding Note}" IsVisible="{Binding HasNote}" Style="{StaticResource BodyMedium}" LineBreakMode="TailTruncation" /></HorizontalStackLayout><Button Grid.RowSpan="2" Grid.ColumnSpan="3" BackgroundColor="Transparent" Text="" Clicked="OnExpenseClicked" CommandParameter="{Binding .}" /></Grid></DataTemplate></CollectionView.ItemTemplate>
  </CollectionView>
  <Grid Grid.Row="1" ColumnDefinitions="56,*" ColumnSpacing="10"><Button Pressed="OnSpeechPressed" Released="OnSpeechReleased" Style="{StaticResource IconButton}" BorderColor="{StaticResource PrimaryLight}" BorderWidth="1"><Button.ImageSource><FileImageSource File="microphone.svg" /></Button.ImageSource></Button><Button Grid.Column="1" Text="Aggiungi spesa" Clicked="OnAddExpenseClicked" Style="{StaticResource PrimaryActionButton}" HeightRequest="56" /></Grid><Border Grid.Row="1" IsVisible="{Binding IsSpeechListening}" InputTransparent="True" TranslationY="-42" BackgroundColor="#E8F3F0" Stroke="Transparent" StrokeShape="RoundRectangle 14" Padding="12,6"><HorizontalStackLayout HorizontalOptions="Center" Spacing="8"><Label Text="●" TextColor="{StaticResource ErrorLight}"/><Label Text="Registra… rilascia per inviare" Style="{StaticResource LabelLarge}"/><Label Text="▮▯▮▯▮" TextColor="{StaticResource PrimaryLight}"/></HorizontalStackLayout></Border>
  <Grid Grid.RowSpan="2" IsVisible="{Binding IsSpeechSheetVisible}" BackgroundColor="#80000000"><Border VerticalOptions="End" BackgroundColor="{StaticResource SurfaceLight}" Stroke="Transparent" StrokeShape="RoundRectangle 28,28,0,0" Padding="22,24,22,28"><VerticalStackLayout Spacing="16"><ActivityIndicator IsVisible="{Binding IsSpeechProcessing}" IsRunning="{Binding IsSpeechProcessing}" /><Label Text="Non ho capito bene." IsVisible="{Binding HasSpeechError}" Style="{StaticResource TitleLarge}" HorizontalTextAlignment="Center" /><Label Text="{Binding SpeechTranscription, StringFormat='Ho sentito: “{0}”'}" Style="{StaticResource BodyMedium}" HorizontalTextAlignment="Center" /><Label Text="Prova: Inserisci 50 euro di spesa su Lavoro&#10;Oppure: Aggiungi spesa di 50 euro alla categoria Auto sotto tag Tagliando" IsVisible="{Binding HasSpeechError}" Style="{StaticResource BodyMedium}" HorizontalTextAlignment="Center" /><Label Text="🔒  Solo sul dispositivo" Style="{StaticResource LabelLarge}" HorizontalTextAlignment="Center" /><Label Text="{Binding SpeechErrorMessage}" IsVisible="{Binding HasSpeechError}" TextColor="{StaticResource ErrorLight}" HorizontalTextAlignment="Center" /><HorizontalStackLayout IsVisible="{Binding HasSpeechError}" HorizontalOptions="Center"><Button Text="Riprova" Clicked="OnRetrySpeechClicked" Style="{StaticResource TextActionButton}" /><Button Text="Chiudi" Clicked="OnCloseSpeechClicked" Style="{StaticResource TextActionButton}" /></HorizontalStackLayout></VerticalStackLayout></Border></Grid>
 </Grid>
</ContentPage>
