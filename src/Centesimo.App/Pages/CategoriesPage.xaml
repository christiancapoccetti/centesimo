<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" x:Class="Centesimo.App.Pages.CategoriesPage" Title="Categorie" SafeAreaEdges="All">
<Grid Padding="20,16" RowDefinitions="Auto,*,Auto" RowSpacing="16">
<VerticalStackLayout Spacing="3"><Label Text="Categorie" Style="{StaticResource HeadlineLarge}" SemanticProperties.HeadingLevel="Level1"/><Label Text="Budget semplici, spese sotto controllo." Style="{StaticResource BodyMedium}"/></VerticalStackLayout>
<Grid Grid.Row="1"><ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"/><VerticalStackLayout IsVisible="{Binding HasError}" Style="{StaticResource EmptyStateLayout}"><Label Text="Impossibile caricare le categorie" Style="{StaticResource TitleLarge}"/><Label Text="{Binding ErrorMessage}" Style="{StaticResource BodyMedium}"/></VerticalStackLayout><VerticalStackLayout IsVisible="{Binding IsEmpty}" Style="{StaticResource EmptyStateLayout}"><Label Text="Nessuna categoria" Style="{StaticResource TitleLarge}"/><Label Text="Creane una per iniziare." Style="{StaticResource BodyMedium}"/></VerticalStackLayout>
<CollectionView ItemsSource="{Binding Categories}" IsVisible="{Binding HasCategories}" SelectionMode="None"><CollectionView.ItemTemplate><DataTemplate><Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,10" Padding="14"><Border.GestureRecognizers><TapGestureRecognizer Tapped="OnEditTapped" CommandParameter="{Binding .}"/></Border.GestureRecognizers><Grid ColumnDefinitions="48,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12"><Border Grid.RowSpan="2" WidthRequest="48" HeightRequest="48" BackgroundColor="{Binding Color}" StrokeThickness="0" StrokeShape="RoundRectangle 16"><Label Text="{Binding Icon, Converter={StaticResource CategoryIconConverter}}" TextColor="White" FontSize="21" HorizontalOptions="Center" VerticalOptions="Center"/></Border><Label Grid.Column="1" Text="{Binding Name}" Style="{StaticResource TitleMedium}"/><Label Grid.Row="1" Grid.Column="1" Text="{Binding BudgetText}" Style="{StaticResource BodyMedium}"/><HorizontalStackLayout Grid.Column="2" Grid.RowSpan="2" Spacing="0"><Button Text="✎" Style="{StaticResource IconButton}" Clicked="OnEditClicked" CommandParameter="{Binding .}" SemanticProperties.Description="Modifica categoria" SemanticProperties.Hint="Apre anche la gestione dei tag"/><Button Text="⋯" Style="{StaticResource IconButton}" Clicked="OnArchiveClicked" CommandParameter="{Binding .}" SemanticProperties.Description="Archivia categoria"/></HorizontalStackLayout></Grid></Border></DataTemplate></CollectionView.ItemTemplate></CollectionView></Grid>
<Button Grid.Row="2" Text="＋  Nuova categoria" Style="{StaticResource PrimaryActionButton}" Clicked="OnNewCategoryClicked" SemanticProperties.Hint="Apre la creazione di una categoria"/>
</Grid></ContentPage>