<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" x:Class="Centesimo.App.Pages.InsightsPage" Title="Insight" SafeAreaEdges="All">
 <ScrollView><VerticalStackLayout Padding="22,22,22,16" Spacing="16">
  <VerticalStackLayout Spacing="2"><Label Text="Insight" Style="{StaticResource HeadlineLarge}"/><Label Text="Guarda come cambiano le tue spese." Style="{StaticResource BodyMedium}"/></VerticalStackLayout>
  <HorizontalStackLayout HorizontalOptions="Center"><Button Text="Questo mese" Clicked="OnMonthClicked" Style="{StaticResource TextActionButton}" BackgroundColor="{Binding MonthSelectorBackground}" SemanticProperties.Description="{Binding MonthSelectorDescription}"/><Button Text="Questo anno" Clicked="OnYearClicked" Style="{StaticResource TextActionButton}" BackgroundColor="{Binding YearSelectorBackground}" SemanticProperties.Description="{Binding YearSelectorDescription}"/></HorizontalStackLayout>
  <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"/><Border Style="{StaticResource TonalCard}" SemanticProperties.Description="{Binding ComparisonDescription}"><VerticalStackLayout Spacing="8"><Label Text="{Binding SummaryLabel}" Style="{StaticResource LabelLarge}"/><Label Text="{Binding Total}" Style="{StaticResource DisplaySmall}"/><Label Text="{Binding Comparison}" Style="{StaticResource BodyMedium}"/><ProgressBar Progress="{Binding ComparisonProgress}" ProgressColor="{StaticResource PrimaryLight}" HeightRequest="6" IsVisible="{Binding HasComparison}"/></VerticalStackLayout></Border>
  <Border Style="{StaticResource SurfaceCard}" IsVisible="{Binding HasError}"><VerticalStackLayout><Label Text="{Binding ErrorMessage}" TextColor="{StaticResource ErrorLight}"/><Button Text="Riprova" Clicked="OnRetryClicked" Style="{StaticResource TextActionButton}"/></VerticalStackLayout></Border>
  <VerticalStackLayout Spacing="10" IsVisible="{Binding HasInsights}"><Label Text="I tuoi insight" Style="{StaticResource TitleLarge}"/><VerticalStackLayout BindableLayout.ItemsSource="{Binding Insights}" Spacing="10"><BindableLayout.ItemTemplate><DataTemplate><Border Style="{StaticResource SurfaceCard}"><Grid><VerticalStackLayout Spacing="4"><Label Text="{Binding Title}" Style="{StaticResource TitleMedium}"/><Label Text="{Binding Description}" Style="{StaticResource BodyMedium}"/></VerticalStackLayout><Button BackgroundColor="Transparent" Text="" Clicked="OnInsightClicked" CommandParameter="{Binding .}" IsVisible="{Binding IsActionable}" SemanticProperties.Description="{Binding Description}" SemanticProperties.Hint="Apri il dettaglio disponibile"/></Grid></Border></DataTemplate></BindableLayout.ItemTemplate></VerticalStackLayout><Button Text="{Binding MoreInsightsText}" IsVisible="{Binding HasMoreInsights}" Clicked="OnMoreInsightsClicked" Style="{StaticResource TextActionButton}"/></VerticalStackLayout>
  <VerticalStackLayout Spacing="10" IsVisible="{Binding HasCategories}"><Label Text="Per categoria" Style="{StaticResource TitleLarge}"/><VerticalStackLayout BindableLayout.ItemsSource="{Binding Categories}" Spacing="10"><BindableLayout.ItemTemplate><DataTemplate><Border Style="{StaticResource SurfaceCard}" SemanticProperties.Description="{Binding Description}"><Grid ColumnDefinitions="44,*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10"><Border Grid.RowSpan="3" Style="{StaticResource CategoryIconContainer}" BackgroundColor="{Binding Color}"><Image Source="{Binding Icon, Converter={StaticResource CategoryIconSourceConverter}}" Style="{StaticResource CategoryIconImage}"/></Border><Label Grid.Column="1" Text="{Binding Name}" Style="{StaticResource TitleMedium}"/><Label Grid.Column="2" Text="{Binding Amount}" Style="{StaticResource TitleMedium}"/><ProgressBar Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Progress="{Binding Progress}" ProgressColor="{StaticResource PrimaryLight}" HeightRequest="6"/><Label Grid.Row="2" Grid.Column="1" Text="{Binding Percentage}" Style="{StaticResource BodyMedium}"/><Label Grid.Row="2" Grid.Column="2" Text="{Binding Change}" Style="{StaticResource BodyMedium}"/><Button Grid.RowSpan="3" Grid.ColumnSpan="3" BackgroundColor="Transparent" Text="" Clicked="OnCategoryClicked" CommandParameter="{Binding .}" IsVisible="{Binding IsActionable}" SemanticProperties.Description="{Binding Description}" SemanticProperties.Hint="Mostra le spese della categoria per il mese"/></Grid></Border></DataTemplate></BindableLayout.ItemTemplate></VerticalStackLayout></VerticalStackLayout>
  <VerticalStackLayout IsVisible="{Binding IsEmpty}" Style="{StaticResource EmptyStateLayout}"><Label Text="Ancora nessuna spesa" Style="{StaticResource TitleLarge}"/><Label Text="Aggiungi una spesa per iniziare a vedere i tuoi insight." Style="{StaticResource BodyMedium}" HorizontalTextAlignment="Center"/><Button Text="Aggiungi spesa" Clicked="OnAddExpenseClicked" Style="{StaticResource PrimaryActionButton}"/></VerticalStackLayout><Label Text="I tuoi insight vengono elaborati solo su questo dispositivo." Style="{StaticResource BodySmall}" HorizontalTextAlignment="Center"/>
 </VerticalStackLayout></ScrollView>
</ContentPage>
