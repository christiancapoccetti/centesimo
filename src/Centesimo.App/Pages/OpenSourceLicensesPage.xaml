<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Centesimo.App.Pages.OpenSourceLicensesPage"
             Title="Licenze open source"
             Shell.TabBarIsVisible="False"
             SafeAreaEdges="All">
    <ScrollView>
        <VerticalStackLayout Padding="22,16" Spacing="16">
            <Label Text="Licenze open source" Style="{StaticResource HeadlineLarge}" />
            <Label Text="Centesimo usa componenti open source. I relativi avvisi e testi di licenza sono riportati qui sotto." Style="{StaticResource BodyMedium}" />
            <Label Text="{Binding Notices}" Style="{StaticResource BodyMedium}" FontSize="12" LineBreakMode="WordWrap" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
