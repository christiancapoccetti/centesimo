<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Centesimo.App.Pages.CategorySpendingPage"
    Title="{Binding Title}"
    Shell.TabBarIsVisible="False"
    SafeAreaEdges="All">
    <Grid Padding="20,16" RowDefinitions="Auto,*" RowSpacing="12">
        <Grid ColumnDefinitions="48,*,48">
            <Button Text="‹" Style="{StaticResource IconButton}" Clicked="OnBackClicked" SemanticProperties.Description="Torna alla Home" />
            <Label Grid.Column="1" Text="{Binding Title}" Style="{StaticResource HeadlineSmall}" HorizontalOptions="Center" VerticalOptions="Center" SemanticProperties.HeadingLevel="Level1" />
        </Grid>
        <CollectionView Grid.Row="1" ItemsSource="{Binding Tags}" SelectionMode="None" ItemSizingStrategy="MeasureAllItems">
            <CollectionView.Header>
                <VerticalStackLayout Spacing="14" Padding="0,0,0,14">
                    <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" MinimumHeightRequest="48" />
                    <Border Style="{StaticResource TonalCard}">
                        <Grid ColumnDefinitions="52,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="14">
                            <Border Grid.RowSpan="5" HeightRequest="52" WidthRequest="52" BackgroundColor="{Binding CategoryColor}" StrokeThickness="0" StrokeShape="RoundRectangle 16">
                                <Image Source="{Binding CategoryIcon, Converter={StaticResource CategoryIconSourceConverter}}" HeightRequest="26" WidthRequest="26" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="1" Text="{Binding MonthTitle}" Style="{StaticResource BodyMedium}" />
                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding Total}" Style="{StaticResource DisplaySmall}" />
                            <Label Grid.Row="2" Grid.Column="1" Text="{Binding BudgetSummary}" Style="{StaticResource BodyMedium}" />
                            <ProgressBar Grid.Row="3" Grid.Column="1" Progress="{Binding BudgetProgress}" HeightRequest="6" ProgressColor="{Binding BudgetStatusColor}" />
                            <Label Grid.Row="4" Grid.Column="1" Text="{Binding BudgetStatus}" TextColor="{Binding BudgetStatusColor}" Style="{StaticResource LabelLarge}" />
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource SurfaceCard}" IsVisible="{Binding HasError}">
                        <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource ErrorLight}" />
                    </Border>
                    <Border Style="{StaticResource SurfaceCard}" IsVisible="{Binding IsEmpty}">
                        <Label Text="Nessuna spesa per questa categoria." Style="{StaticResource BodyMedium}" HorizontalTextAlignment="Center" />
                    </Border>
                    <Label Text="Spese per tag" Style="{StaticResource TitleLarge}" IsVisible="{Binding HasTags}" SemanticProperties.HeadingLevel="Level2" />
                </VerticalStackLayout>
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,10" Padding="0">
                        <VerticalStackLayout Spacing="0">
                            <Grid Padding="14" ColumnDefinitions="*,Auto,36" RowDefinitions="Auto,Auto" ColumnSpacing="8">
                                <Label Text="{Binding Name}" Style="{StaticResource TitleMedium}" />
                                <Label Grid.Column="1" Text="{Binding Total}" Style="{StaticResource TitleMedium}" />
                                <Label Grid.Row="1" Text="{Binding CountText}" Style="{StaticResource BodyMedium}" />
                                <Label Grid.Column="2" Grid.RowSpan="2" Text="›" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center" />
                                <Button Grid.RowSpan="2" Grid.ColumnSpan="3" ZIndex="2" BackgroundColor="Transparent" Text="" Pressed="OnCardPressed" Released="OnCardReleased" Clicked="OnTagClicked" CommandParameter="{Binding .}" SemanticProperties.Description="{Binding Name}" SemanticProperties.Hint="Mostra le spese del tag" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
