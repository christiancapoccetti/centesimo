<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" x:Class="Centesimo.App.Pages.ExpenseHistoryPage" Title="Storico" Shell.TabBarIsVisible="False" SafeAreaEdges="All">
<Grid Padding="20,16" RowDefinitions="Auto,Auto,*" RowSpacing="14">
<Grid ColumnDefinitions="48,*" ColumnSpacing="8"><Button Text="‹" Style="{StaticResource IconButton}" Clicked="OnBackClicked" SemanticProperties.Description="Torna alla schermata precedente"/><VerticalStackLayout Grid.Column="1" Spacing="2"><Label Text="Storico spese" Style="{StaticResource HeadlineLarge}" SemanticProperties.HeadingLevel="Level1"/><Label Text="Rivedi e correggi i movimenti" Style="{StaticResource BodyMedium}"/></VerticalStackLayout></Grid>
<Border Grid.Row="1" Style="{StaticResource TonalCard}" Padding="8"><Grid ColumnDefinitions="48,*,48"><Button Text="‹" Style="{StaticResource IconButton}" IsEnabled="{Binding CanNavigatePrevious}" Clicked="OnPreviousMonthClicked" SemanticProperties.Description="Mese precedente"/><Label Grid.Column="1" Text="{Binding MonthTitle}" Style="{StaticResource TitleMedium}" HorizontalOptions="Center" VerticalOptions="Center"/><Button Grid.Column="2" Text="›" Style="{StaticResource IconButton}" IsEnabled="{Binding CanGoNext}" Clicked="OnNextMonthClicked" SemanticProperties.Description="Mese successivo"/></Grid></Border>
<Grid Grid.Row="2"><ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"/><Border Style="{StaticResource SurfaceCard}" IsVisible="{Binding HasError}" VerticalOptions="Start"><Label Text="{Binding ErrorMessage}" TextColor="{StaticResource ErrorLight}"/></Border><Border Style="{StaticResource SurfaceCard}" IsVisible="{Binding IsEmpty}"><VerticalStackLayout Style="{StaticResource EmptyStateLayout}"><Label Text="Nessuna spesa questo mese" Style="{StaticResource TitleLarge}"/><Label Text="Le spese aggiunte compariranno qui." Style="{StaticResource BodyMedium}"/></VerticalStackLayout></Border>
<CollectionView ItemsSource="{Binding Expenses}" IsVisible="{Binding HasExpenses}" SelectionMode="None"><CollectionView.ItemsLayout><LinearItemsLayout Orientation="Vertical" ItemSpacing="8"/></CollectionView.ItemsLayout><CollectionView.ItemTemplate><DataTemplate><Border Style="{StaticResource SurfaceCard}" Padding="14" SemanticProperties.Hint="Tocca per modificare la spesa"><Grid ColumnDefinitions="44,*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="3"><Border Grid.RowSpan="3" HeightRequest="44" WidthRequest="44" BackgroundColor="{Binding Color}" StrokeThickness="0" StrokeShape="RoundRectangle 14"><Label Text="{Binding Icon, Converter={StaticResource CategoryIconConverter}}" TextColor="White" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/></Border><Label Grid.Column="1" Text="{Binding CategoryName}" Style="{StaticResource TitleMedium}"/><Label Grid.Column="2" Text="{Binding Amount}" Style="{StaticResource TitleMedium}"/><Label Grid.Row="1" Grid.Column="1" Text="{Binding Date}" Style="{StaticResource BodyMedium}"/><Label Grid.Row="2" Grid.Column="1" Text="{Binding Note}" IsVisible="{Binding HasNote}" Style="{StaticResource BodyMedium}"/><Button Grid.RowSpan="3" Grid.ColumnSpan="3" ZIndex="2" BackgroundColor="Transparent" Text="" Pressed="OnCardPressed" Released="OnCardReleased" Clicked="OnExpenseTapped" CommandParameter="{Binding .}" SemanticProperties.Hint="Tocca per modificare la spesa"/></Grid></Border></DataTemplate></CollectionView.ItemTemplate></CollectionView>
</Grid></Grid></ContentPage>