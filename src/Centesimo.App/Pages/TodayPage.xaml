<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" x:Class="Centesimo.App.Pages.TodayPage" Title="Oggi" SafeAreaEdges="All">
<Grid Padding="20,16" RowDefinitions="*,Auto" RowSpacing="12">
<ScrollView><VerticalStackLayout Spacing="20">
<Grid ColumnDefinitions="*,Auto"><VerticalStackLayout Spacing="2"><Label Text="Buongiorno" Style="{StaticResource HeadlineLarge}" SemanticProperties.HeadingLevel="Level1"/><Label Text="Il tuo mese in breve" Style="{StaticResource BodyMedium}"/></VerticalStackLayout><Button Grid.Column="1" Text="Storico  ›" Style="{StaticResource TextActionButton}" Clicked="OnExpenseHistoryClicked" SemanticProperties.Hint="Apre lo storico mensile delle spese"/></Grid>
<ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" MinimumHeightRequest="48"/>
<Border Style="{StaticResource SurfaceCard}" IsVisible="{Binding HasError}"><Label Text="{Binding ErrorMessage}" TextColor="{StaticResource ErrorLight}"/></Border>
<Border Style="{StaticResource TonalCard}" IsVisible="{Binding HasCategories}"><VerticalStackLayout Spacing="10"><Label Text="SPESO QUESTO MESE" Style="{StaticResource LabelLarge}" TextColor="{StaticResource OnPrimaryContainerLight}"/><Label Text="{Binding MonthlyTotal}" Style="{StaticResource DisplaySmall}" TextColor="{StaticResource OnPrimaryContainerLight}"/><Label Text="{Binding BudgetSummary}" Style="{StaticResource BodyMedium}"/><ProgressBar Progress="{Binding BudgetProgress}" HeightRequest="8" ProgressColor="{StaticResource PrimaryLight}"/></VerticalStackLayout></Border>
<VerticalStackLayout Spacing="10" IsVisible="{Binding HasCategories}"><Label Text="Categorie" Style="{StaticResource TitleLarge}" SemanticProperties.HeadingLevel="Level2"/><VerticalStackLayout BindableLayout.ItemsSource="{Binding Categories}" Spacing="8"><BindableLayout.ItemTemplate><DataTemplate><Border Style="{StaticResource SurfaceCard}" Padding="14"><Grid ColumnDefinitions="44,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12"><Border Grid.RowSpan="2" HeightRequest="44" WidthRequest="44" BackgroundColor="{Binding Color}" StrokeThickness="0" StrokeShape="RoundRectangle 14"><Label Text="{Binding Icon, Converter={StaticResource CategoryIconConverter}}" TextColor="White" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/></Border><Label Grid.Column="1" Text="{Binding Name}" Style="{StaticResource TitleMedium}"/><Label Grid.Column="2" Text="{Binding AmountSummary}" Style="{StaticResource BodyMedium}"/><ProgressBar Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Progress="{Binding Progress}" HeightRequest="5" ProgressColor="{StaticResource PrimaryLight}"/></Grid></Border></DataTemplate></BindableLayout.ItemTemplate></VerticalStackLayout></VerticalStackLayout>
<VerticalStackLayout Spacing="10"><Label Text="Oggi" Style="{StaticResource TitleLarge}" SemanticProperties.HeadingLevel="Level2"/><Border Style="{StaticResource SurfaceCard}" IsVisible="{Binding IsExpenseEmpty}"><VerticalStackLayout Spacing="4"><Label Text="Nessuna spesa oggi" Style="{StaticResource TitleMedium}"/><Label Text="Aggiungi la prima spesa quando vuoi." Style="{StaticResource BodyMedium}"/></VerticalStackLayout></Border><VerticalStackLayout BindableLayout.ItemsSource="{Binding Expenses}" Spacing="8"><BindableLayout.ItemTemplate><DataTemplate><Border Style="{StaticResource SurfaceCard}" Padding="14" SemanticProperties.Hint="Tocca per modificare la spesa"><Grid ColumnDefinitions="44,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12"><Border Grid.RowSpan="2" HeightRequest="44" WidthRequest="44" BackgroundColor="{Binding Color}" StrokeThickness="0" StrokeShape="RoundRectangle 14"><Label Text="{Binding Icon, Converter={StaticResource CategoryIconConverter}}" TextColor="White" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/></Border><Label Grid.Column="1" Text="{Binding CategoryName}" Style="{StaticResource TitleMedium}"/><Label Grid.Column="2" Text="{Binding Amount}" Style="{StaticResource TitleMedium}"/><Label Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Note}" IsVisible="{Binding HasNote}" Style="{StaticResource BodyMedium}"/><Button Grid.RowSpan="3" Grid.ColumnSpan="3" ZIndex="2" BackgroundColor="Transparent" Text="" Pressed="OnCardPressed" Released="OnCardReleased" Clicked="OnTodayExpenseTapped" CommandParameter="{Binding .}" SemanticProperties.Hint="Tocca per modificare la spesa"/></Grid></Border></DataTemplate></BindableLayout.ItemTemplate></VerticalStackLayout></VerticalStackLayout>
</VerticalStackLayout></ScrollView>
<Button Grid.Row="1" Text="＋  Aggiungi spesa" Clicked="OnAddExpenseClicked" Style="{StaticResource PrimaryActionButton}" HorizontalOptions="Fill" SemanticProperties.Hint="Apre l'inserimento di una nuova spesa"/>
</Grid></ContentPage>