<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Centesimo.App.Pages.CategoriesPage"
             Title="Categorie"
             SafeAreaEdges="All">
    <Grid Padding="24" RowDefinitions="Auto,*,Auto" RowSpacing="16">
        <VerticalStackLayout Grid.Row="0" Spacing="4">
            <Label Text="Categorie"
                   Style="{StaticResource HeadlineLarge}"
                   SemanticProperties.HeadingLevel="Level1" />
            <Label Text="Organizza le spese e assegna un budget mensile."
                   Style="{StaticResource BodyMedium}" />
        </VerticalStackLayout>

        <Grid Grid.Row="1">
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryDark}}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />

            <VerticalStackLayout IsVisible="{Binding HasError}"
                                 Style="{StaticResource EmptyStateLayout}">
                <Label Text="Impossibile caricare le categorie"
                       Style="{StaticResource TitleLarge}"
                       HorizontalTextAlignment="Center"
                       SemanticProperties.HeadingLevel="Level2" />
                <Label Text="{Binding ErrorMessage}"
                       Style="{StaticResource BodyMedium}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding IsEmpty}"
                                 Style="{StaticResource EmptyStateLayout}">
                <Label Text="Nessuna categoria"
                       Style="{StaticResource TitleLarge}"
                       HorizontalTextAlignment="Center"
                       SemanticProperties.HeadingLevel="Level2" />
                <Label Text="Crea una categoria per organizzare le tue spese."
                       Style="{StaticResource BodyMedium}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <CollectionView ItemsSource="{Binding Categories}"
                            IsVisible="{Binding HasCategories}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource SurfaceCard}"
                                Margin="0,0,0,12">
                            <Grid ColumnDefinitions="48,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12">
                                <Border Grid.RowSpan="2"
                                        WidthRequest="48"
                                        HeightRequest="48"
                                        BackgroundColor="{Binding Color}"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 24">
                                    <Label Text="{Binding Icon}"
                                           TextColor="White"
                                           FontSize="11"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center" />
                                </Border>
                                <Label Grid.Column="1"
                                       Text="{Binding Name}"
                                       Style="{StaticResource TitleLarge}"
                                       FontSize="18" />
                                <Label Grid.Row="1" Grid.Column="1"
                                       Text="{Binding BudgetText}"
                                       Style="{StaticResource BodyMedium}" />
                                <VerticalStackLayout Grid.Column="2" Grid.RowSpan="2" Spacing="4">
                                    <Button Text="Modifica"
                                            MinimumHeightRequest="48"
                                            Clicked="OnEditClicked"
                                            CommandParameter="{Binding .}" />
                                    <Button Text="Archivia"
                                            MinimumHeightRequest="48"
                                            Clicked="OnArchiveClicked"
                                            CommandParameter="{Binding .}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <Button Grid.Row="2"
                Text="Nuova categoria"
                Style="{StaticResource PrimaryActionButton}"
                Clicked="OnNewCategoryClicked"
                SemanticProperties.Hint="Apre la creazione di una categoria" />
    </Grid>
</ContentPage>
