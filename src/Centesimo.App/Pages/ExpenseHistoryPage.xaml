<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Centesimo.App.Pages.ExpenseHistoryPage"
             Title="Tutte le spese"
             SafeAreaEdges="All">
    <Grid Padding="24" RowDefinitions="Auto,Auto,*" RowSpacing="16">
        <Label Grid.Row="0"
               Text="Tutte le spese"
               Style="{StaticResource HeadlineLarge}"
               SemanticProperties.HeadingLevel="Level1" />

        <Grid Grid.Row="1" ColumnDefinitions="48,*,48" ColumnSpacing="8">
            <Button Text="‹"
                    FontSize="24"
                    MinimumHeightRequest="48"
                    MinimumWidthRequest="48"
                    IsEnabled="{Binding CanNavigatePrevious}"
                    Clicked="OnPreviousMonthClicked"
                    SemanticProperties.Description="Mese precedente" />
            <Label Grid.Column="1"
                   Text="{Binding MonthTitle}"
                   Style="{StaticResource TitleLarge}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
            <Button Grid.Column="2"
                    Text="›"
                    FontSize="24"
                    MinimumHeightRequest="48"
                    MinimumWidthRequest="48"
                    IsEnabled="{Binding CanGoNext}"
                    Clicked="OnNextMonthClicked"
                    SemanticProperties.Description="Mese successivo" />
        </Grid>

        <Grid Grid.Row="2">
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}" />
            <Border Style="{StaticResource SurfaceCard}"
                    IsVisible="{Binding HasError}"
                    VerticalOptions="Start">
                <Label Text="{Binding ErrorMessage}"
                       TextColor="#B3261E" />
            </Border>
            <Border Style="{StaticResource SurfaceCard}"
                    IsVisible="{Binding IsEmpty}">
                <VerticalStackLayout Style="{StaticResource EmptyStateLayout}">
                    <Label Text="Nessuna spesa in questo mese"
                           Style="{StaticResource TitleLarge}"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Le spese aggiunte compariranno qui."
                           Style="{StaticResource BodyMedium}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>
            <CollectionView ItemsSource="{Binding Expenses}"
                            IsVisible="{Binding HasExpenses}"
                            SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical"
                                       ItemSpacing="8" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource SurfaceCard}"
                                Padding="16">
                            <Grid ColumnDefinitions="48,*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="4">
                                <Border Grid.RowSpan="3"
                                        HeightRequest="48"
                                        WidthRequest="48"
                                        BackgroundColor="{Binding Color}"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 24">
                                    <Label Text="{Binding Icon}"
                                           TextColor="White"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>
                                <Label Grid.Column="1"
                                       Text="{Binding CategoryName}"
                                       Style="{StaticResource TitleMedium}" />
                                <Label Grid.Column="2"
                                       Text="{Binding Amount}"
                                       Style="{StaticResource TitleMedium}" />
                                <Label Grid.Row="1"
                                       Grid.Column="1"
                                       Text="{Binding Date}"
                                       Style="{StaticResource BodyMedium}" />
                                <Label Grid.Row="2"
                                       Grid.Column="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding Note}"
                                       IsVisible="{Binding HasNote}"
                                       Style="{StaticResource BodyMedium}" />
                                <HorizontalStackLayout Grid.Row="1"
                                                       Grid.RowSpan="2"
                                                       Grid.Column="2"
                                                       HorizontalOptions="End"
                                                       VerticalOptions="End"
                                                       Spacing="4">
                                    <Button Text="Modifica"
                                            MinimumHeightRequest="48"
                                            CommandParameter="{Binding .}"
                                            Clicked="OnEditClicked" />
                                    <Button Text="Elimina"
                                            MinimumHeightRequest="48"
                                            CommandParameter="{Binding .}"
                                            Clicked="OnDeleteClicked" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>
