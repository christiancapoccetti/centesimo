<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" xmlns:sys="clr-namespace:System;assembly=System.Runtime" x:Class="Centesimo.App.Pages.ExpenseEditorPage" Title="{Binding Title}" Shell.NavBarIsVisible="False" Shell.TabBarIsVisible="False" SafeAreaEdges="All" BackgroundColor="#80000000">
<Grid Padding="12,48,12,12"><Border VerticalOptions="End" BackgroundColor="White" StrokeThickness="0" Padding="20" StrokeShape="RoundRectangle 28"><Grid RowDefinitions="Auto,*,Auto" RowSpacing="14"><Grid ColumnDefinitions="48,*,48"><Button Text="×" Style="{StaticResource IconButton}" Clicked="OnCancelClicked" SemanticProperties.Description="Annulla"/><Label Grid.Column="1" Text="{Binding Title}" Style="{StaticResource HeadlineSmall}" HorizontalOptions="Center" VerticalOptions="Center"/><BoxView Grid.Column="2" WidthRequest="48"/></Grid><ScrollView Grid.Row="1"><VerticalStackLayout Spacing="14"><ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"/><Border Style="{StaticResource TonalCard}" Padding="14"><Grid ColumnDefinitions="Auto,*" ColumnSpacing="8"><Label Text="€" FontSize="30" VerticalOptions="Center"/><Entry Grid.Column="1" Text="{Binding Amount}" Placeholder="0,00" Keyboard="Numeric" FontSize="30" MinimumHeightRequest="56" SemanticProperties.Description="Importo della spesa in euro"/></Grid></Border><Grid ColumnDefinitions="*,*" ColumnSpacing="10"><VerticalStackLayout Spacing="4"><Label Text="Categoria" Style="{StaticResource LabelLarge}"/><Picker ItemsSource="{Binding Categories}" ItemDisplayBinding="{Binding Name}" SelectedItem="{Binding SelectedCategory}" SelectedIndexChanged="OnCategoryChanged" MinimumHeightRequest="48" Title="Scegli"/></VerticalStackLayout><VerticalStackLayout Grid.Column="1" Spacing="4"><Label Text="Data" Style="{StaticResource LabelLarge}"/><DatePicker Date="{Binding OccurredOn}" MaximumDate="{x:Static sys:DateTime.Today}" MinimumHeightRequest="48"/></VerticalStackLayout></Grid><VerticalStackLayout Spacing="4" IsVisible="{Binding HasTags}"><Label Text="Tag facoltativo" Style="{StaticResource LabelLarge}"/><Picker ItemsSource="{Binding Tags}" ItemDisplayBinding="{Binding Name}" SelectedItem="{Binding SelectedTag}" MinimumHeightRequest="48" Title="Nessun tag"/></VerticalStackLayout><VerticalStackLayout Spacing="4"><Label Text="Nota facoltativa" Style="{StaticResource LabelLarge}"/><Editor Text="{Binding Note}" Placeholder="Aggiungi una nota" AutoSize="TextChanges" MinimumHeightRequest="72" MaxLength="500"/></VerticalStackLayout><Label Text="{Binding ErrorMessage}" IsVisible="{Binding HasError}" TextColor="{StaticResource ErrorLight}"/></VerticalStackLayout></ScrollView><VerticalStackLayout Grid.Row="2" Spacing="4"><Button Text="Elimina spesa" IsVisible="{Binding IsEditMode}" Style="{StaticResource TextActionButton}" TextColor="{StaticResource ErrorLight}" MinimumHeightRequest="48" Clicked="OnDeleteClicked" SemanticProperties.Description="Elimina definitivamente questa spesa"/><Button Text="Salva spesa" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryActionButton}" HorizontalOptions="Fill"/></VerticalStackLayout></Grid></Border></Grid></ContentPage>