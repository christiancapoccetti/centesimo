<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Centesimo.App.Controls.CategoryBreakdownList"
             x:Name="Root">
  <VerticalStackLayout BindableLayout.ItemsSource="{Binding ItemsSource, Source={x:Reference Root}}" Spacing="10">
    <BindableLayout.ItemTemplate>
      <DataTemplate>
        <Border Style="{StaticResource SurfaceCard}" SemanticProperties.Description="{Binding Description}">
          <Grid ColumnDefinitions="44,*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10">
            <Border Grid.RowSpan="3" Style="{StaticResource CategoryIconContainer}" BackgroundColor="{Binding Color}">
              <Image Source="{Binding Icon, Converter={StaticResource CategoryIconSourceConverter}}" Style="{StaticResource CategoryIconImage}" />
            </Border>
            <Label Grid.Column="1" Text="{Binding Name}" Style="{StaticResource TitleMedium}" />
            <Label Grid.Column="2" Text="{Binding Amount}" Style="{StaticResource TitleMedium}" />
            <ProgressBar Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Progress="{Binding Progress}" ProgressColor="{StaticResource PrimaryLight}" HeightRequest="6" />
            <Label Grid.Row="2" Grid.Column="1" Text="{Binding SecondaryLabel}" Style="{StaticResource BodyMedium}" />
            <Label Grid.Row="2" Grid.Column="2" Text="{Binding StatusLabel}" Style="{StaticResource BodyMedium}" />
            <Button Grid.RowSpan="3" Grid.ColumnSpan="3" BackgroundColor="Transparent" Text="" Clicked="OnCategoryClicked" CommandParameter="{Binding .}" IsVisible="{Binding IsActionable}" SemanticProperties.Description="{Binding Description}" SemanticProperties.Hint="Mostra il dettaglio della categoria" />
          </Grid>
        </Border>
      </DataTemplate>
    </BindableLayout.ItemTemplate>
  </VerticalStackLayout>
</ContentView>
