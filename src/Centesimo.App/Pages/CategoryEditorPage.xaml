<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Centesimo.App.Pages.CategoryEditorPage"
             Title="{Binding Title}"
             SafeAreaEdges="All">
    <Grid Padding="24" RowDefinitions="*,Auto" RowSpacing="16">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="16">
                <Label Text="{Binding Title}"
                       Style="{StaticResource HeadlineLarge}"
                       SemanticProperties.HeadingLevel="Level1" />
                <Entry Text="{Binding Name}"
                       Placeholder="Nome"
                       MinimumHeightRequest="48"
                       SemanticProperties.Description="Nome della categoria" />
                <Picker Title="Icona"
                        ItemsSource="{Binding Icons}"
                        SelectedItem="{Binding SelectedIcon}"
                        MinimumHeightRequest="48" />
                <Picker Title="Colore"
                        ItemsSource="{Binding Colors}"
                        SelectedItem="{Binding SelectedColor}"
                        MinimumHeightRequest="48" />
                <Entry Text="{Binding Budget}"
                       Placeholder="Budget mensile opzionale"
                       Keyboard="Numeric"
                       MinimumHeightRequest="48"
                       SemanticProperties.Description="Budget mensile in euro" />
                <Button Text="Rimuovi budget"
                        Command="{Binding ClearBudgetCommand}"
                        MinimumHeightRequest="48" />                <Label Text="{Binding ErrorMessage}"
                       IsVisible="{Binding HasError}"
                       TextColor="#BA1A1A"
                       Style="{StaticResource BodyMedium}" />
            </VerticalStackLayout>
        </ScrollView>
        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12">
            <Button Text="Annulla"
                    MinimumHeightRequest="48"
                    Clicked="OnCancelClicked" />
            <Button Grid.Column="1"
                    Text="Salva"
                    Style="{StaticResource PrimaryActionButton}"
                    Command="{Binding SaveCommand}" />
        </Grid>
    </Grid>
</ContentPage>
