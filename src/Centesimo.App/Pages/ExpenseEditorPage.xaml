<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" xmlns:sys="clr-namespace:System;assembly=mscorlib" xmlns:controls="clr-namespace:Centesimo.App.Controls" x:Class="Centesimo.App.Pages.ExpenseEditorPage" Title="{Binding Title}" Shell.NavBarIsVisible="False" SafeAreaEdges="All">
    <Grid Padding="22,12,22,16" RowDefinitions="Auto,*,Auto" RowSpacing="12">
        <Grid ColumnDefinitions="Auto,*,Auto" HeightRequest="48">
            <Button Text="Chiudi" Style="{StaticResource TextActionButton}" Clicked="OnCancelClicked" />
            <Label Grid.Column="1" Text="{Binding Title}" Style="{StaticResource TitleLarge}" HorizontalTextAlignment="Center" VerticalOptions="Center" />
            <BoxView Grid.Column="2" WidthRequest="64" />
        </Grid>
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="22" Padding="0,14,0,8">
                <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" />
                <VerticalStackLayout Spacing="4">
                    <Label Text="Quanto hai speso?" Style="{StaticResource BodyMedium}" HorizontalTextAlignment="Center" />
                    <Entry Text="{Binding Amount}" Placeholder="0,00 €" Keyboard="Numeric" FontFamily="OpenSansSemibold" FontSize="44" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <BoxView HeightRequest="1" Color="{StaticResource OutlineLight}" />
                <VerticalStackLayout Spacing="8">
                    <Label Text="DATA" Style="{StaticResource LabelLarge}" />
                    <Border Style="{StaticResource FieldContainer}"><DatePicker Date="{Binding OccurredOn}" MaximumDate="{x:Static sys:DateTime.Today}" MinimumHeightRequest="48" /></Border>
                    <Label Text="CATEGORIA" Style="{StaticResource LabelLarge}" />
                    <controls:CategorySelector Items="{Binding Categories}" CategoryTapped="OnCategorySelectorTapped" />
                    <Border Style="{StaticResource FieldContainer}" IsVisible="{Binding HasTags}"><Picker ItemsSource="{Binding Tags}" ItemDisplayBinding="{Binding Name}" SelectedItem="{Binding SelectedTag}" Title="Tag (facoltativo)" MinimumHeightRequest="48" /></Border>
                </VerticalStackLayout>
                <VerticalStackLayout Spacing="8">
                    <Label Text="NOTE" Style="{StaticResource LabelLarge}" />
                    <Border Style="{StaticResource FieldContainer}"><Editor Text="{Binding Note}" Placeholder="Aggiungi una nota" AutoSize="TextChanges" MinimumHeightRequest="76" MaxLength="500" /></Border>
                </VerticalStackLayout>
                <Label Text="{Binding ErrorMessage}" IsVisible="{Binding HasError}" TextColor="{StaticResource ErrorLight}" />
            </VerticalStackLayout>
        </ScrollView>
        <VerticalStackLayout Grid.Row="2" Spacing="2"><Button Text="Elimina spesa" IsVisible="{Binding IsEditMode}" Style="{StaticResource TextActionButton}" TextColor="{StaticResource ErrorLight}" Clicked="OnDeleteClicked" /><Button Text="Salva spesa" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryActionButton}" /></VerticalStackLayout>
    </Grid>
</ContentPage>
