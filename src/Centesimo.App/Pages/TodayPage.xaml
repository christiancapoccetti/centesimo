<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" xmlns:controls="clr-namespace:Centesimo.App.Controls" x:Class="Centesimo.App.Pages.TodayPage" Title="Oggi" SafeAreaEdges="All">
 <Grid Padding="22,14,22,16" RowDefinitions="*,Auto,56" RowSpacing="12">
  <ScrollView><VerticalStackLayout Spacing="24" Padding="0,8,0,14">
    <Grid ColumnDefinitions="*,Auto"><VerticalStackLayout Spacing="2"><Label Text="Ciao!" Style="{StaticResource HeadlineLarge}" /><Label Text="{Binding HomeSubtitle}" Style="{StaticResource BodyMedium}" /></VerticalStackLayout><Border Grid.Column="1" Style="{StaticResource CategoryIconContainer}" BackgroundColor="{StaticResource PrimaryContainerLight}" VerticalOptions="Center"><Label Text="€" Style="{StaticResource TitleLarge}" TextColor="{StaticResource PrimaryLight}" HorizontalOptions="Center" VerticalOptions="Center" /></Border></Grid>
    <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" />
    <Border Style="{StaticResource SurfaceCard}" IsVisible="{Binding HasError}"><Label Text="{Binding ErrorMessage}" TextColor="{StaticResource ErrorLight}" /></Border>
    <VerticalStackLayout Spacing="12"><Grid ColumnDefinitions="40,*,40"><Button Text="‹" Style="{StaticResource IconButton}" IsEnabled="{Binding CanGoPrevious}" Clicked="OnPreviousMonthClicked" /><Button Grid.Column="1" WidthRequest="184" HorizontalOptions="Center" Text="{Binding MonthTitle}" BackgroundColor="{StaticResource PrimaryContainerLight}" TextColor="{StaticResource OnPrimaryContainerLight}" FontFamily="OpenSansSemibold" FontSize="16" Padding="20,0" MinimumHeightRequest="48" CornerRadius="24" Command="{Binding ToggleOverviewCommand}" SemanticProperties.Description="Cambia visualizzazione tra mese e anno" /><Button Grid.Column="2" Text="›" Style="{StaticResource IconButton}" IsEnabled="{Binding CanGoNext}" Clicked="OnNextMonthClicked" /></Grid><Border Style="{StaticResource TonalCard}" Padding="22"><VerticalStackLayout Spacing="8"><Label Text="{Binding SummaryLabel}" Style="{StaticResource LabelLarge}" TextColor="{StaticResource OnPrimaryContainerLight}" /><Label Text="{Binding MonthlyTotal}" Style="{StaticResource DisplaySmall}" TextColor="{StaticResource OnPrimaryContainerLight}" /><Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0"><Label Text="{Binding BudgetSummary}" Style="{StaticResource BodyMedium}" /><Label Grid.Column="1" Text="Budget" Style="{StaticResource LabelLarge}" /></Grid><ProgressBar Progress="{Binding BudgetProgress}" HeightRequest="6" ProgressColor="{StaticResource PrimaryLight}" /></VerticalStackLayout></Border></VerticalStackLayout>
    <VerticalStackLayout Spacing="10" IsVisible="{Binding HasCategories}"><Label Text="Per categoria" Style="{StaticResource TitleLarge}" /><controls:CategoryBreakdownList ItemsSource="{Binding Categories}" CategoryClicked="OnCategoryClicked" /></VerticalStackLayout>
   </VerticalStackLayout></ScrollView>
<VerticalStackLayout Grid.Row="1" HorizontalOptions="End" Spacing="0"><Label Text="{Binding SpeechAvailabilityMessage}" IsVisible="{Binding IsSpeechPreparing}" Style="{StaticResource BodySmall}" HorizontalTextAlignment="End" MaximumWidthRequest="250" /><Label Text="{Binding SpeechAvailabilityMessage}" IsVisible="{Binding IsSpeechPreparationFailed}" Style="{StaticResource BodySmall}" TextColor="{StaticResource ErrorLight}" HorizontalTextAlignment="End" MaximumWidthRequest="250" /><Button Text="{Binding SpeechPreparationActionText}" Clicked="OnRetrySpeechPreparationClicked" IsVisible="{Binding IsSpeechPreparationFailed}" Style="{StaticResource TextActionButton}" HorizontalOptions="End" /></VerticalStackLayout><Grid Grid.Row="2" ColumnDefinitions="*,56" ColumnSpacing="10"><Button Text="Aggiungi spesa" Clicked="OnAddExpenseClicked" Style="{StaticResource PrimaryActionButton}" HeightRequest="56" /><Grid Grid.Column="1"><Button IsEnabled="{Binding IsSpeechReady}" Pressed="OnSpeechPressed" Released="OnSpeechReleased" Style="{StaticResource VoiceActionButton}" SemanticProperties.Description="Comando vocale"><Button.ImageSource><FileImageSource File="microphone.svg" /></Button.ImageSource></Button><ActivityIndicator IsVisible="{Binding IsSpeechPreparing}" IsRunning="{Binding IsSpeechPreparing}" InputTransparent="True" Color="{StaticResource PrimaryLight}" /><Button IsVisible="{Binding IsSpeechPreparationFailed}" BackgroundColor="Transparent" Text="" Clicked="OnInactiveSpeechClicked" /></Grid></Grid><Border Grid.Row="2" IsVisible="{Binding IsSpeechListening}" InputTransparent="True" TranslationY="-42" BackgroundColor="#E8F3F0" Stroke="Transparent" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="12,6"><HorizontalStackLayout HorizontalOptions="Center" Spacing="8"><Label Text="●" TextColor="{StaticResource ErrorLight}"/><Label Text="Registra… rilascia per inviare" Style="{StaticResource LabelLarge}"/><Label Text="▮▯▮▯▮" TextColor="{StaticResource PrimaryLight}"/></HorizontalStackLayout></Border>
  <Grid Grid.RowSpan="3" IsVisible="{Binding IsSpeechSheetVisible}" BackgroundColor="#80000000"><Border VerticalOptions="End" BackgroundColor="{StaticResource SurfaceLight}" Stroke="Transparent" StrokeThickness="0" StrokeShape="RoundRectangle 28,28,0,0" Padding="22,24,22,28"><VerticalStackLayout Spacing="16"><ActivityIndicator IsVisible="{Binding IsSpeechProcessing}" IsRunning="{Binding IsSpeechProcessing}" /><Label Text="Non ho capito bene." IsVisible="{Binding HasSpeechError}" Style="{StaticResource TitleLarge}" HorizontalTextAlignment="Center" /><Label Text="{Binding SpeechTranscription, StringFormat='Ho sentito: “{0}”'}" Style="{StaticResource BodyMedium}" HorizontalTextAlignment="Center" /><Label Text="Prova: Inserisci 50 euro di spesa su Lavoro&#10;Oppure: Aggiungi spesa di 50 euro alla categoria Auto sotto tag Tagliando" IsVisible="{Binding HasSpeechError}" Style="{StaticResource BodyMedium}" HorizontalTextAlignment="Center" /><Label Text="🔒  Solo sul dispositivo" Style="{StaticResource LabelLarge}" HorizontalTextAlignment="Center" /><Label Text="{Binding SpeechErrorMessage}" IsVisible="{Binding HasSpeechError}" TextColor="{StaticResource ErrorLight}" HorizontalTextAlignment="Center" /><HorizontalStackLayout IsVisible="{Binding HasSpeechError}" HorizontalOptions="Center"><Button Text="Riprova" Clicked="OnRetrySpeechClicked" Style="{StaticResource TextActionButton}" /><Button Text="Chiudi" Clicked="OnCloseSpeechClicked" Style="{StaticResource TextActionButton}" /></HorizontalStackLayout></VerticalStackLayout></Border></Grid>
 </Grid>
</ContentPage>
