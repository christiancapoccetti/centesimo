<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" x:Class="Centesimo.App.Controls.CategorySelector" x:Name="Root"><FlexLayout BindableLayout.ItemsSource="{Binding Items, Source={x:Reference Root}}" Direction="Row" Wrap="Wrap"><BindableLayout.ItemTemplate><DataTemplate><Border FlexLayout.Basis="25%" Padding="4" Stroke="Transparent" StrokeShape="RoundRectangle 14"><Border.GestureRecognizers><TapGestureRecognizer Tapped="OnTapped"/></Border.GestureRecognizers><Border.Triggers><DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True"><Setter Property="Stroke" Value="{StaticResource PrimaryLight}"/><Setter Property="StrokeThickness" Value="2"/><Setter Property="BackgroundColor" Value="{StaticResource PrimaryContainerLight}"/></DataTrigger></Border.Triggers><VerticalStackLayout Spacing="3" HorizontalOptions="Center"><Border WidthRequest="38" HeightRequest="38" BackgroundColor="{Binding Color}" Style="{StaticResource CategoryIconContainer}"><Image Source="{Binding Icon, Converter={StaticResource CategoryIconSourceConverter}}" Style="{StaticResource CategoryIconImage}"/></Border><Label Text="{Binding Name}" FontSize="10" LineBreakMode="TailTruncation" HorizontalTextAlignment="Center"/></VerticalStackLayout></Border></DataTemplate></BindableLayout.ItemTemplate></FlexLayout></ContentView>
