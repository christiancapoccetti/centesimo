<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Centesimo.App.Pages.LicensePage"
             Title="Licenza"
             Shell.TabBarIsVisible="False"
             SafeAreaEdges="All">
    <ScrollView>
        <VerticalStackLayout Padding="22,16" Spacing="16">
            <Label Text="Centesimo" Style="{StaticResource HeadlineLarge}" />
            <Label Text="Copyright © 2026 Christian Capoccetti" Style="{StaticResource BodyMedium}" />
            <Label Text="Questo programma è software libero: puoi ridistribuirlo e/o modificarlo secondo i termini della GNU General Public License, versione 3." Style="{StaticResource BodyMedium}" />
            <Label Text="Il programma è distribuito nella speranza che sia utile, ma SENZA ALCUNA GARANZIA." Style="{StaticResource BodyMedium}" />
            <Label Text="Il codice sorgente corrispondente è disponibile su github.com/christiancapoccetti/centesimo." Style="{StaticResource BodyMedium}" />
            <Label Text="{Binding LicenseText}" Style="{StaticResource BodyMedium}" FontSize="11" LineBreakMode="WordWrap" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
