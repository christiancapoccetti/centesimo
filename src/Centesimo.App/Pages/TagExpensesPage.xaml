<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" x:Class="Centesimo.App.Pages.TagExpensesPage" Title="{Binding Title}" Shell.TabBarIsVisible="False" SafeAreaEdges="All">
    <Grid Padding="20,16" RowDefinitions="Auto,*" RowSpacing="12">
        <Grid ColumnDefinitions="48,*,48"><Button Text="‹" Style="{StaticResource IconButton}" Clicked="OnBackClicked" SemanticProperties.Description="Torna al dettaglio categoria"/><Label Grid.Column="1" Text="{Binding Title}" Style="{StaticResource HeadlineSmall}" HorizontalOptions="Center" VerticalOptions="Center" SemanticProperties.HeadingLevel="Level1"/></Grid>
        <CollectionView Grid.Row="1" ItemsSource="{Binding Expenses}" SelectionMode="None">
            <CollectionView.Header><VerticalStackLayout Spacing="14" Padding="0,0,0,14"><ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" MinimumHeightRequest="48"/><Border Style="{StaticResource TonalCard}"><VerticalStackLayout Spacing="4"><Label Text="{Binding MonthTitle}" Style="{StaticResource BodyMedium}"/><Label Text="{Binding Total}" Style="{StaticResource DisplaySmall}"/></VerticalStackLayout></Border><Border Style="{StaticResource SurfaceCard}" IsVisible="{Binding HasError}"><Label Text="{Binding ErrorMessage}" TextColor="{StaticResource ErrorLight}"/></Border><Border Style="{StaticResource SurfaceCard}" IsVisible="{Binding IsEmpty}"><Label Text="Nessuna spesa per questo tag." Style="{StaticResource BodyMedium}" HorizontalTextAlignment="Center"/></Border></VerticalStackLayout></CollectionView.Header>
            <CollectionView.ItemTemplate><DataTemplate><Border Style="{StaticResource SurfaceCard}" Padding="14" Margin="0,0,0,8" SemanticProperties.Hint="Tocca per modificare la spesa"><Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto"><Label Text="{Binding Date}" Style="{StaticResource BodyMedium}"/><Label Grid.Column="1" Text="{Binding Amount}" Style="{StaticResource TitleMedium}"/><Label Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Note}" IsVisible="{Binding HasNote}" Style="{StaticResource BodyMedium}" MaxLines="1" LineBreakMode="TailTruncation"/><Button Grid.RowSpan="2" Grid.ColumnSpan="2" ZIndex="2" BackgroundColor="Transparent" Text="" Pressed="OnCardPressed" Released="OnCardReleased" Clicked="OnExpenseClicked" CommandParameter="{Binding .}" SemanticProperties.Hint="Tocca per modificare la spesa"/></Grid></Border></DataTemplate></CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>