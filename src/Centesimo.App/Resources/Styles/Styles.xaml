<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
<Style TargetType="Page" ApplyToDerivedTypes="True"><Setter Property="BackgroundColor" Value="{StaticResource SurfaceLight}" /></Style>
<Style TargetType="ContentPage" ApplyToDerivedTypes="True"><Setter Property="BackgroundColor" Value="{StaticResource SurfaceLight}" /></Style>
<Style TargetType="Label"><Setter Property="FontFamily" Value="OpenSansRegular" /><Setter Property="FontSize" Value="14" /><Setter Property="TextColor" Value="{StaticResource OnSurfaceLight}" /></Style>
<Style x:Key="PrimaryActionButton" TargetType="Button"><Setter Property="BackgroundColor" Value="{StaticResource PrimaryLight}" /><Setter Property="TextColor" Value="White" /><Setter Property="FontFamily" Value="OpenSansSemibold" /><Setter Property="FontSize" Value="16" /><Setter Property="HeightRequest" Value="56" /><Setter Property="MinimumHeightRequest" Value="56" /><Setter Property="MaximumHeightRequest" Value="56" /><Setter Property="CornerRadius" Value="20" /><Setter Property="Padding" Value="24,0" /></Style>
<Style x:Key="TextActionButton" TargetType="Button"><Setter Property="BackgroundColor" Value="Transparent" /><Setter Property="TextColor" Value="{StaticResource PrimaryLight}" /><Setter Property="FontFamily" Value="OpenSansSemibold" /><Setter Property="MinimumHeightRequest" Value="48" /><Setter Property="Padding" Value="12,8" /></Style>
<Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource TextActionButton}"><Setter Property="FontSize" Value="22" /><Setter Property="MinimumWidthRequest" Value="48" /><Setter Property="Padding" Value="8" /></Style>
<Style x:Key="VoiceActionButton" TargetType="Button"><Setter Property="BackgroundColor" Value="{StaticResource PrimaryContainerLight}" /><Setter Property="TextColor" Value="{StaticResource PrimaryLight}" /><Setter Property="WidthRequest" Value="56" /><Setter Property="HeightRequest" Value="56" /><Setter Property="MinimumWidthRequest" Value="56" /><Setter Property="MinimumHeightRequest" Value="56" /><Setter Property="MaximumWidthRequest" Value="56" /><Setter Property="MaximumHeightRequest" Value="56" /><Setter Property="CornerRadius" Value="28" /><Setter Property="BorderWidth" Value="0" /><Setter Property="Padding" Value="14" /></Style>
<Style x:Key="SurfaceCard" TargetType="Border"><Setter Property="BackgroundColor" Value="White" /><Setter Property="Stroke" Value="{StaticResource OutlineLight}" /><Setter Property="StrokeThickness" Value="1" /><Setter Property="Padding" Value="18" /><Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="20" /></Setter.Value></Setter></Style>
<Style x:Key="TonalCard" TargetType="Border" BasedOn="{StaticResource SurfaceCard}"><Setter Property="BackgroundColor" Value="{StaticResource PrimaryContainerLight}" /><Setter Property="StrokeThickness" Value="0" /></Style>
<Style x:Key="FieldContainer" TargetType="Border"><Setter Property="BackgroundColor" Value="{StaticResource SurfaceContainerHighLight}" /><Setter Property="StrokeThickness" Value="0" /><Setter Property="Padding" Value="14,8" /><Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="14" /></Setter.Value></Setter></Style>
<Style x:Key="CategoryIconContainer" TargetType="Border"><Setter Property="WidthRequest" Value="44" /><Setter Property="HeightRequest" Value="44" /><Setter Property="StrokeThickness" Value="0" /><Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="14" /></Setter.Value></Setter></Style>
<Style x:Key="CategoryIconImage" TargetType="Image"><Setter Property="HeightRequest" Value="22" /><Setter Property="WidthRequest" Value="22" /><Setter Property="HorizontalOptions" Value="Center" /><Setter Property="VerticalOptions" Value="Center" /></Style>
<Style x:Key="EmptyStateLayout" TargetType="VerticalStackLayout"><Setter Property="Spacing" Value="8" /><Setter Property="HorizontalOptions" Value="Center" /><Setter Property="VerticalOptions" Value="Center" /></Style>
<Style TargetType="Shell" ApplyToDerivedTypes="True"><Setter Property="Shell.BackgroundColor" Value="{StaticResource SurfaceLight}" /><Setter Property="Shell.ForegroundColor" Value="{StaticResource PrimaryLight}" /><Setter Property="Shell.TitleColor" Value="{StaticResource OnSurfaceLight}" /><Setter Property="Shell.UnselectedColor" Value="{StaticResource OnSurfaceVariantLight}" /><Setter Property="Shell.NavBarIsVisible" Value="False" /><Setter Property="Shell.TabBarBackgroundColor" Value="White" /><Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource PrimaryLight}" /><Setter Property="Shell.TabBarTitleColor" Value="{StaticResource PrimaryLight}" /><Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource OnSurfaceVariantLight}" /></Style>
</ResourceDictionary>
