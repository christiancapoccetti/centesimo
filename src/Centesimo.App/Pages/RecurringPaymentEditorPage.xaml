<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" x:Class="Centesimo.App.Pages.RecurringPaymentEditorPage" Shell.NavBarIsVisible="False" SafeAreaEdges="All"><Grid Padding="22,12,22,16" RowDefinitions="Auto,*,Auto"><Grid ColumnDefinitions="Auto,*,Auto"><Button Text="Chiudi" Style="{StaticResource TextActionButton}" Clicked="OnCloseClicked"/><Label Grid.Column="1" Text="{Binding Title}" Style="{StaticResource TitleLarge}" HorizontalTextAlignment="Center" VerticalOptions="Center"/><BoxView Grid.Column="2" WidthRequest="64"/></Grid><ScrollView Grid.Row="1"><VerticalStackLayout Spacing="16" Padding="0,14"><Entry Text="{Binding Amount}" Placeholder="Importo (es. 25,00)" Keyboard="Numeric" FontSize="32" HorizontalTextAlignment="Center"/><Label Text="CATEGORIA" Style="{StaticResource LabelLarge}"/><FlexLayout BindableLayout.ItemsSource="{Binding Categories}" Direction="Row" Wrap="Wrap"><BindableLayout.ItemTemplate><DataTemplate><Border FlexLayout.Basis="20%" HeightRequest="56" Style="{StaticResource FieldContainer}"><Border.GestureRecognizers><TapGestureRecognizer Tapped="OnCategoryTapped"/></Border.GestureRecognizers><Label Text="{Binding Name}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="11"/></Border></DataTemplate></BindableLayout.ItemTemplate></FlexLayout><Border Style="{StaticResource FieldContainer}" IsVisible="{Binding HasTags}"><Picker ItemsSource="{Binding Tags}" ItemDisplayBinding="Name" SelectedItem="{Binding SelectedTag}" Title="Tag (facoltativo)"/></Border><Label Text="RIPETIZIONE" Style="{StaticResource LabelLarge}"/><Border Style="{StaticResource FieldContainer}"><Picker ItemsSource="{Binding Frequencies}" SelectedItem="{Binding Frequency}"/></Border><Label Text="PROSSIMA SCADENZA" Style="{StaticResource LabelLarge}"/><Border Style="{StaticResource FieldContainer}"><DatePicker Date="{Binding NextDueOn}"/></Border><Switch IsToggled="{Binding HasEndDate}"/><Label Text="FINE (FACOLTATIVA)" Style="{StaticResource LabelLarge}"/><Border Style="{StaticResource FieldContainer}"><DatePicker Date="{Binding EndsOn}" IsEnabled="{Binding CanSelectEndDate}"/></Border><Border Style="{StaticResource FieldContainer}"><Editor Text="{Binding Note}" Placeholder="Nota (facoltativa)" AutoSize="TextChanges"/></Border><Label Text="{Binding ErrorMessage}" IsVisible="{Binding HasError}" TextColor="{StaticResource ErrorLight}"/></VerticalStackLayout></ScrollView><Button Grid.Row="2" Text="Salva pagamento" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryActionButton}"/></Grid></ContentPage>
